<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- SophaxChat does not track users and sends no data to third parties. -->

    <!-- No cross-app or cross-site tracking -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No tracking domains -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- No data is collected from users -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- System APIs accessed -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <!-- UserDefaults: stores app settings (aliases, blocked peers, disappearing-message
             timers, app-lock toggle, etc.) written and read only by this app. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: Access info from the same app that wrote it -->
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
